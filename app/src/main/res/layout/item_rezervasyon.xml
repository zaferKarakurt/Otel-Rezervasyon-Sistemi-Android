<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#2D3748"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_rez_oda_no"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Oda No: #101"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_rez_musteri_adi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Müşteri Adı"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_rez_tarih_araligi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Giriş: 2023-11-01 / Çıkış: 2023-11-05"
        android:textColor="#A0AEC0"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_rez_toplam_fiyat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tutar: 4000.00 TL"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#48BB78" />

        <Button
            android:id="@+id/btn_rez_iptal"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#E53E3E"
            android:text="İPTAL ET"
            android:textSize="10sp"
            android:padding="0dp" />
    </LinearLayout>

</LinearLayout>
</androidx.cardview.widget.CardView>